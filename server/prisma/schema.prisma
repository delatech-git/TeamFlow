// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum IdeaStatus {
  DRAFT
  NEW
  PLANNED
  COMPLETED
  CANCELLED
}

enum StickerType {
  TEXT
  NOTE
  IMAGE
  EMOJI
}

model User {
  id           String  @id @default(uuid())
  username     String  @unique
  email        String  @unique
  passwordHash String
  fullName     String?
  avatarUrl    String?
  role         Role    @default(USER)

  ideas     Idea[]
  stickers  Sticker[]
  comments  Comment[]
  reactions Reaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id    String  @id @default(uuid())
  name  String  @unique
  color String?

  ideas Idea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Idea {
  id               String     @id @default(uuid())
  title            String
  shortDescription String
  coverImageUrl    String?
  status           IdeaStatus @default(DRAFT)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  tags     Tag[]
  board    Board?
  comments Comment[]
  summary  PlanSummary?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Board {
  id String @id @default(uuid())

  ideaId String @unique
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  stickers Sticker[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sticker {
  id      String      @id @default(uuid())
  type    StickerType @default(TEXT)
  content String

  x        Float
  y        Float
  width    Float?
  height   Float?
  color    String?
  isPinned Boolean @default(false)

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  reactions Reaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reaction {
  id    String @id @default(uuid())
  emoji String

  stickerId String
  sticker   Sticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([stickerId, userId, emoji])
}

model Comment {
  id      String @id @default(uuid())
  content String

  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanSummary {
  id            String @id @default(uuid())
  summary       String
  decisionsJson Json?

  ideaId String @unique
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  createdById String
  createdAt   DateTime @default(now())
}
